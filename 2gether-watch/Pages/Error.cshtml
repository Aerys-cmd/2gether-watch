@page
@model ErrorModel
@{
    ViewData["Title"] = "Error — 2gether Watch";
    ViewData["BodyClass"] = "min-h-screen bg-slate-950 text-white flex items-center justify-center p-4";
}

<div class="w-full max-w-xs sm:max-w-sm text-center space-y-5">
    <a href="/" class="hover:opacity-75 transition-opacity duration-150 block">
        <img src="/logo.svg" alt="2gWatch" width="360" height="96" class="w-48 mx-auto opacity-50" />
    </a>
    <div class="bg-slate-900 border border-slate-700/60 p-6 space-y-3">
        <p class="text-slate-200 text-sm font-semibold">Something went wrong</p>
        @if (Model.ShowRequestId)
        {
            <p class="text-slate-500 text-[10px] font-mono break-all">Request ID: @Model.RequestId</p>
        }
        <a href="/"
            class="inline-block mt-1 px-4 py-2 bg-indigo-600 hover:bg-indigo-500 border border-indigo-600 hover:border-indigo-500 text-sm font-semibold transition-colors duration-150">
            ← Back to home
        </a>
    </div>
</div>

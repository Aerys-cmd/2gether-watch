@using Microsoft.Extensions.Options
@inject IOptions<FeedbackHubOptions> FeedbackHubOptions
@{
    var title = ViewData["Title"] as string ?? "2gether Watch";
    var bodyClass = ViewData["BodyClass"] as string ?? "min-h-screen bg-slate-950 text-slate-100";
    var viewport = ViewData["Viewport"] as string ?? "width=device-width, initial-scale=1.0";
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="@viewport" />
    <title>@title</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico" />
    <script src="https://cdn.tailwindcss.com"></script>
    @await RenderSectionAsync("Head", required: false)
</head>

<body class="@bodyClass">
    @RenderBody()
    @if (FeedbackHubOptions.Value.Enabled)
    {
        <script src="https://feedback-hub.lunavex.com/widget/feedback-widget.js"
                data-project-key="@FeedbackHubOptions.Value.PublicKey" data-locale="auto"></script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>

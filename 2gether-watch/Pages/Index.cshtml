@page "/room/{id}"
@model IndexModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <title>2gether Watch – Room @Model.RoomId</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>

<body class="h-screen w-screen bg-gray-900 text-white">
    <div class="flex flex-col sm:flex-row h-full">
        <!-- Left: Screen Share -->
        <div class="flex-1 flex flex-col bg-black items-center justify-center w-full sm:w-2/3">
            <video id="remoteScreen" autoplay playsinline class="w-full h-full object-contain"></video>
            <p id="roomVacantText" class="controls absolute top-4 left-1/2 transform -translate-x-1/2 text-sm text-gray-400 bg-black/50 px-3 py-1 rounded-full pointer-events-none"></p>
        </div>

        <!-- Right: Webcams -->
        <div class="w-full flex flex-col bg-gray-800 p-2 space-y-2 sm:w-1/3">
            <video id="remoteCam" autoplay playsinline class="w-full h-1/2 object-cover rounded-lg"></video>
            <video id="localCam" autoplay playsinline muted
                class="w-full h-1/2 -scale-x-100 object-cover rounded-lg"></video>
        </div>
    </div>

    <!-- Floating Buttons -->
    <div class="controls absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-3">
        <button id="btnCam" title="Toggle camera" class="p-3 bg-blue-600 hover:bg-blue-700 rounded-full transition">🎥</button>
        <button id="btnMic" title="Toggle mic" class="p-3 bg-green-600 hover:bg-green-700 rounded-full transition">🎙️</button>
        <button id="btnShare" title="Share screen" class="p-3 bg-purple-600 hover:bg-purple-700 rounded-full transition">🖥️</button>
        <button id="btnCopy" title="Copy room link" class="p-3 bg-gray-600 hover:bg-gray-500 rounded-full transition text-sm font-medium px-4">🔗 Copy Link</button>
    </div>

    <script>
        const ROOM_ID = "@Model.RoomId";
    </script>
    <script src="/js/webrtc.js"></script>
    <script>
        const controls = document.getElementsByClassName("controls");
        let timer;

        function resetTimer() {
            for (let control of controls) {
                control.classList.remove("opacity-0");
            }
            clearTimeout(timer);
            timer = setTimeout(() => {
                for (let control of controls) {
                    control.classList.add("opacity-0");
                }
            }, 3000);
        }

        ["mousemove", "keydown", "click", "scroll"].forEach(evt => {
            document.addEventListener(evt, resetTimer);
        });

        resetTimer();
    </script>
</body>

</html>
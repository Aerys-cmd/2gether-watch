@page
@model IndexModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>2gether Watch</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="min-h-screen bg-gray-900 text-white flex items-center justify-center p-6">
    <div class="max-w-md w-full space-y-8 text-center">

        <!-- Title -->
        <div>
            <h1 class="text-5xl font-bold tracking-tight">
                2gether<span class="text-purple-400">·</span>Watch
            </h1>
            <p class="mt-3 text-gray-400 text-lg">Watch together, in sync, from anywhere.</p>
        </div>

        <!-- Create Room -->
        <button id="btnCreate"
            class="w-full py-4 bg-purple-600 hover:bg-purple-700 rounded-xl text-xl font-semibold shadow-lg transition">
            🎬 Create a Room
        </button>

        <!-- Divider -->
        <div class="flex items-center space-x-4">
            <hr class="flex-1 border-gray-700" />
            <span class="text-gray-500 text-sm whitespace-nowrap">or join an existing room</span>
            <hr class="flex-1 border-gray-700" />
        </div>

        <!-- Join Room -->
        <div class="flex space-x-2">
            <input id="roomIdInput" type="text" placeholder="Enter room ID…" autocomplete="off"
                class="flex-1 px-4 py-3 bg-gray-800 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-purple-500 transition" />
            <button id="btnJoin"
                class="px-6 py-3 bg-blue-600 hover:bg-blue-700 rounded-xl font-semibold transition">
                Join
            </button>
        </div>

        <p id="errMsg" class="text-red-400 text-sm hidden">Please enter a room ID.</p>
    </div>

    <script>
        function generateRoomId() {
            // crypto.randomUUID() gives a UUID; take the first segment for brevity
            if (typeof crypto !== "undefined" && crypto.randomUUID) {
                return crypto.randomUUID().split("-")[0];
            }
            return Math.random().toString(36).substring(2, 9);
        }

        document.getElementById("btnCreate").addEventListener("click", () => {
            window.location.href = "/room/" + generateRoomId();
        });

        const ROOM_ID_PATTERN = /^[A-Za-z0-9_-]+$/;

        document.getElementById("btnJoin").addEventListener("click", () => {
            const id = document.getElementById("roomIdInput").value.trim();
            const errMsg = document.getElementById("errMsg");
            if (!id) {
                errMsg.textContent = "Please enter a room ID.";
                errMsg.classList.remove("hidden");
                return;
            }
            if (!ROOM_ID_PATTERN.test(id)) {
                errMsg.textContent = "Room ID may only contain letters, numbers, hyphens and underscores.";
                errMsg.classList.remove("hidden");
                return;
            }
            window.location.href = "/room/" + id;
        });

        document.getElementById("roomIdInput").addEventListener("keydown", e => {
            document.getElementById("errMsg").classList.add("hidden");
            if (e.key === "Enter") document.getElementById("btnJoin").click();
        });
    </script>
</body>

</html>
@page
@model IndexModel
@{
    ViewData["Title"] = "2gether Watch — Watch Videos Together in Perfect Sync | Free Watch Party App";
    ViewData["BodyClass"] = "min-h-screen bg-slate-950 text-white flex items-center justify-center p-4";
}

@section Head {
    <meta name="title" content="2gether Watch — Watch Videos Together in Perfect Sync" />
    <meta name="description" content="Watch videos together in perfect sync from anywhere. Free watch party app with audio/video calls, live chat, and screen sharing. No sign-up required. Private, secure, and powered by WebRTC." />
    <meta name="keywords" content="watch together, watch party, video sync, watch videos together, online watch party, video chat, screen sharing, WebRTC, sync video, YouTube watch party, group video watching, free watch party" />
    <meta name="author" content="2gether Watch" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="@Model.BaseUrl/" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="@Model.BaseUrl/" />
    <meta property="og:title" content="2gether Watch — Watch Videos Together in Perfect Sync" />
    <meta property="og:description" content="Watch videos together in perfect sync from anywhere. Free watch party app with audio/video calls, live chat, and screen sharing. No sign-up required." />
    <meta property="og:image" content="@Model.BaseUrl/favicon.ico" />
    <meta property="og:site_name" content="2gether Watch" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:url" content="@Model.BaseUrl/" />
    <meta name="twitter:title" content="2gether Watch — Watch Videos Together in Perfect Sync" />
    <meta name="twitter:description" content="Watch videos together in perfect sync from anywhere. Free watch party app with audio/video calls, live chat, and screen sharing. No sign-up required." />
    <meta name="twitter:image" content="@Model.BaseUrl/favicon.ico" />

    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "WebApplication",
      "name": "2gether Watch",
      "alternateName": "2gether-watch",
      "url": "@Model.BaseUrl",
      "description": "Watch videos together in perfect sync from anywhere. Free watch party app with audio/video calls, live chat, and screen sharing powered by WebRTC.",
      "applicationCategory": "MultimediaApplication",
      "operatingSystem": "Any",
      "offers": {
        "@@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "featureList": [
        "Synchronized video playback",
        "Audio and video calls",
        "Live chat",
        "Screen sharing",
        "Private rooms",
        "No sign-up required",
        "Supports up to 10 viewers",
        "YouTube and direct video URL support"
      ],
      "browserRequirements": "Requires JavaScript. Requires HTML5.",
      "permissions": "camera, microphone, display-capture"
    }
    </script>

    <style>
        @@keyframes float-up-down {
            0%, 100% { transform: translateY(0px); }
            50%       { transform: translateY(-10px); }
        }
        .film-frame { animation: float-up-down 3.2s ease-in-out infinite; }
    </style>
}

    <div class="w-full max-w-xs sm:max-w-sm">

        <!-- Animated logo -->
        <div class="flex justify-center mb-5 select-none">
            <div class="film-frame">
                <a href="/" class="hover:opacity-85 transition-opacity duration-150 block">
                    <!-- width/height match the SVG's natural ratio (360×96) so the browser
                         reserves the right amount of space before the file loads (no CLS).
                         The CSS class makes it fluid within its container. -->
                    <img src="/logo.svg" alt="2gWatch" width="360" height="96" class="w-full" />
                </a>
            </div>
        </div>

        <!-- Brand -->
        <div class="text-center mb-6 select-none">
            <p class="mt-1 text-slate-400 text-xs tracking-wide">Watch together, in sync, from anywhere.</p>
        </div>

        <!-- Card -->
        <div class="bg-slate-900 border border-slate-700/60 p-5 space-y-4">

            <!-- Display name -->
            <div class="space-y-1">
                <label for="usernameInput" class="text-[10px] text-slate-400 uppercase tracking-wider">Display name</label>
                <input id="usernameInput" type="text" placeholder="Enter your name…" maxlength="30"
                    autocomplete="nickname"
                    class="w-full h-8 px-3 bg-slate-800 border border-slate-700 text-slate-100
                           placeholder-slate-500 focus:outline-none focus:border-indigo-500 transition-colors duration-150 text-sm" />
            </div>

            <!-- Create Room -->
            <button id="btnCreate"
                class="w-full h-9 bg-indigo-600 hover:bg-indigo-500 border border-indigo-600 hover:border-indigo-500
                       text-sm font-semibold transition-colors duration-150">
                Create New Room
            </button>

            <!-- Divider -->
            <div class="flex items-center gap-3">
                <div class="flex-1 h-px bg-slate-700/50"></div>
                <span class="text-slate-500 text-[10px] shrink-0 uppercase tracking-wider">or join existing</span>
                <div class="flex-1 h-px bg-slate-700/50"></div>
            </div>

            <!-- Join Room -->
            <div class="space-y-1.5">
                <div class="flex">
                    <input id="roomIdInput" type="text" placeholder="Enter room ID…"
                        autocomplete="off" spellcheck="false" maxlength="64"
                        class="flex-1 h-8 px-3 bg-slate-800 border border-slate-700 border-r-0 text-slate-100
                               placeholder-slate-500 focus:outline-none focus:border-indigo-500 transition-colors duration-150
                               font-mono text-sm min-w-0" />
                    <button id="btnJoin"
                        class="h-8 px-4 bg-slate-700 hover:bg-slate-600 border border-slate-700 hover:border-slate-600
                               font-semibold text-sm transition-colors duration-150 shrink-0 text-slate-200">
                        Join →
                    </button>
                </div>
                <p id="errMsg" class="hidden text-red-400 text-xs flex items-center gap-1">
                    <span id="errText">Please enter a room ID.</span>
                </p>
            </div>
        </div>

        <!-- Feature row -->
        <div class="mt-3 grid grid-cols-4 gap-1.5 text-center">
            <div class="bg-slate-900 border border-slate-700/60 py-2.5 px-1">
                <div class="text-base mb-0.5">🔒</div>
                <div class="text-[10px] text-slate-400">Private</div>
            </div>
            <div class="bg-slate-900 border border-slate-700/60 py-2.5 px-1">
                <div class="text-base mb-0.5">▶️</div>
                <div class="text-[10px] text-slate-400">Synced</div>
            </div>
            <div class="bg-slate-900 border border-slate-700/60 py-2.5 px-1">
                <div class="text-base mb-0.5">💬</div>
                <div class="text-[10px] text-slate-400">Chat</div>
            </div>
            <div class="bg-slate-900 border border-slate-700/60 py-2.5 px-1">
                <div class="text-base mb-0.5">🖥️</div>
                <div class="text-[10px] text-slate-400">Screen</div>
            </div>
        </div>

        <p class="mt-4 text-center text-slate-500 text-[10px] uppercase tracking-wider">No sign-up required · Free forever</p>
    </div>

@section Scripts {
    <script>
        // ── Persist display name ───────────────────────────────────────
        const usernameInput = document.getElementById("usernameInput");
        const saved = localStorage.getItem("2gw_username");
        if (saved) usernameInput.value = saved;

        function saveName() {
            const name = usernameInput.value.trim();
            if (name) localStorage.setItem("2gw_username", name);
        }

        // ── Room helpers ───────────────────────────────────────────────
        function generateRoomId() {
            if (typeof crypto !== "undefined" && crypto.randomUUID) {
                // Strip dashes and take 12 hex chars → 48-bit of UUID randomness.
                return crypto.randomUUID().replace(/-/g, "").slice(0, 12);
            }
            return Math.random().toString(36).substring(2, 14);
        }

        document.getElementById("btnCreate").addEventListener("click", () => {
            saveName();
            window.location.href = "/room/" + generateRoomId();
        });

        const ROOM_ID_PATTERN = /^[A-Za-z0-9_-]{1,64}$/;

        document.getElementById("btnJoin").addEventListener("click", () => {
            const id = document.getElementById("roomIdInput").value.trim();
            const errMsg  = document.getElementById("errMsg");
            const errText = document.getElementById("errText");
            if (!id) {
                errText.textContent = "Please enter a room ID.";
                errMsg.classList.remove("hidden");
                return;
            }
            if (!ROOM_ID_PATTERN.test(id)) {
                errText.textContent = "Room ID may only contain letters, numbers, hyphens and underscores.";
                errMsg.classList.remove("hidden");
                return;
            }
            saveName();
            window.location.href = "/room/" + id;
        });

        document.getElementById("roomIdInput").addEventListener("input", () => {
            document.getElementById("errMsg").classList.add("hidden");
        });

        document.getElementById("roomIdInput").addEventListener("keydown", e => {
            if (e.key === "Enter") document.getElementById("btnJoin").click();
        });
    </script>
}

@page "/room/{id}"
@model IndexModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>
    <title>Oda - @Model.RoomId</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>

<body class="h-screen w-screen bg-gray-900 text-white">
    <div class="flex flex-col sm:flex-row h-full">
        <!-- Left: Screen Share -->
        <div class="flex-1 flex flex-col bg-black flex items-center justify-center w-full sm:w-2/3 ">
            <video id="remoteScreen" autoplay playsinline class="w-full h-full object-contain"></video>
            <p id="roomVacantText" class="controls">
            </p>
        </div>

        <!-- Right: Webcams -->
        <div class="w-full flex flex-col bg-gray-800 p-2 space-y-2 sm:w-1/3">
            <video id="remoteCam" autoplay playsinline class="w-full h-1/2 object-cover rounded-lg"></video>
            <video id="localCam" autoplay playsinline muted class="w-full h-1/2 object-cover rounded-lg"></video>
        </div>
    </div>

    <!-- Floating Buttons -->
    <div class="controls absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-4">
        <button id="btnCam" class="p-3 bg-blue-600 rounded-full">🎥</button>
        <button id="btnShare" class="p-3 bg-purple-600 rounded-full">🖥️</button>
    </div>

    <script>
        const ROOM_ID = "@Model.RoomId";
    </script>
    <script src="/js/webrtc.js"></script>
    <script>
        const controls = document.getElementsByClassName("controls");
        let timer;

        function resetTimer() {

            for (let control of controls) {
                control.classList.remove("opacity-0")
            }

            clearTimeout(timer);
            timer = setTimeout(() => {
                for (let control of controls) {
                    control.classList.add("opacity-0")
                }
            }, 3000);
        }

        // reset on any interaction
        ["mousemove", "keydown", "click", "scroll"].forEach(evt => {
            document.addEventListener(evt, resetTimer);
        });

        // start timer initially
        resetTimer();
    </script>
</body>

</html>
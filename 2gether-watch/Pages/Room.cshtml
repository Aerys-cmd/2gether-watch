@page "/room/{id?}"
@model RoomModel
@using Microsoft.Extensions.Options
@inject IOptions<FeedbackHubOptions> FeedbackHubOptions
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>2gether Watch — Room @Model.RoomId</title>

    <!-- Prevent indexing of private room pages -->
    <meta name="robots" content="noindex, nofollow" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico" />

    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        /* --footer-h is referenced by both the footer and the mobile chat drawer */
        :root { --footer-h: 3.5rem; }

        body { height: 100dvh; }
        @@supports not (height: 100dvh) { body { height: 100vh; } }

        .vid-label {
            position: absolute; bottom: 4px; left: 6px;
            font-size: 9px; line-height: 1;
            color: rgba(255,255,255,0.5); background: rgba(0,0,0,0.55);
            padding: 2px 5px;
            pointer-events: none; user-select: none;
        }

        @@keyframes status-pulse { 0%,100%{opacity:1} 50%{opacity:.35} }
        .status-pulse { animation: status-pulse 1.8s ease-in-out infinite; }

        /* YouTube iframe fills its container */
        #ytPlayerContainer iframe { width: 100%; height: 100%; }

        /* Chat scrollbar */
        #chatMessages, #chatMessagesMobile {
            scrollbar-width: thin;
            scrollbar-color: rgba(148,163,184,0.12) transparent;
        }
        #chatMessages::-webkit-scrollbar,
        #chatMessagesMobile::-webkit-scrollbar { width: 4px; }
        #chatMessages::-webkit-scrollbar-thumb,
        #chatMessagesMobile::-webkit-scrollbar-thumb {
            background: rgba(148,163,184,0.12);
        }

        /* Camera tile — base sizes */
        .cam-tile { height: 7rem; }
        @@media (min-width: 1024px) { .cam-tile { height: 7rem; width: 100%; } }

        /* ── Mobile / touch-device overrides ─────────────────────────────────
           Mobile browsers cannot load arbitrary video URLs and do not support
           getDisplayMedia, so hide both the URL bar and the screen-share button.
           (hover:none) + (pointer:coarse) reliably targets touch devices
           regardless of screen orientation or viewport width. */
        @@media (hover: none) and (pointer: coarse) {
            #urlBar         { display: none !important; }
            #btnScreenShare { display: none !important; }
        }

        /* ── Landscape on phones / small tablets (width < 1024 px) ─────────
           Footer is completely hidden — its controls move into the header.
           Cameras shift to a 22 % right sidebar.
           Video stage fills ~85 % of screen height on a typical phone. */
        @@media (orientation: landscape) and (max-width: 1023px) {
            /* Footer gone — drawer anchors to very bottom of screen */
            :root  { --footer-h: 0px; }
            footer { display: none !important; }

            /* Header: taller to comfortably fit the touch buttons (≥ 44 px) */
            header { min-height: 3rem !important; }

            /* Reveal the landscape control strip inside the header */
            #landscapeControls { display: flex !important; }

            /* Hide the verbose status text — just keep the status dot */
            #statusText { display: none !important; }

            /* Main: switch from column to row so cameras sit on the right */
            main { flex-direction: row !important; }

            /* Camera sidebar: right side, 22 % of viewport width */
            #camSidebar {
                flex-direction: column !important;
                width: 22% !important;
                flex-shrink: 0 !important;
                border-top: none !important;
                border-left: 1px solid rgba(30, 41, 59, 0.8) !important;
                overflow: hidden;
            }

            /* Camera grid: fills full sidebar height, scrolls vertically */
            #camGrid {
                display: flex !important;
                flex-direction: column !important;
                overflow-x: hidden !important;
                overflow-y: auto !important;
                flex: 1 1 auto !important;
                border-bottom: none !important;
                max-height: 100% !important;
            }

            /* Camera tiles: fill sidebar width with a 4:3 aspect ratio */
            .cam-tile {
                height: auto !important;
                width: 100% !important;
                aspect-ratio: 4 / 3;
                flex-shrink: 0;
            }
        }

        /* Helper classes: show different content on desktop vs. mobile */
        .mobile-hint { display: none; }
        @@media (hover: none) and (pointer: coarse) {
            .desktop-hint { display: none; }
            .mobile-hint  { display: block; }
        }

        /* Safe-area padding for page chrome — keeps content clear of the notch in all orientations.
           max() ensures we keep at least the Tailwind base padding even when the inset is 0. */
        header {
            padding-top: env(safe-area-inset-top, 0rem);
            padding-left: max(0.75rem, env(safe-area-inset-left, 0rem)) !important;
            padding-right: max(0.75rem, env(safe-area-inset-right, 0rem)) !important;
        }
        #urlBar, footer {
            padding-left: max(0.75rem, env(safe-area-inset-left, 0rem)) !important;
            padding-right: max(0.75rem, env(safe-area-inset-right, 0rem)) !important;
        }
        @@media (min-width: 640px) {
            header, footer {
                padding-left: max(1.25rem, env(safe-area-inset-left, 0rem)) !important;
                padding-right: max(1.25rem, env(safe-area-inset-right, 0rem)) !important;
            }
        }

        /* Camera placeholder */
        .cam-ph {
            display: flex; align-items: center; justify-content: center;
            width: 100%; height: 100%;
            background: #0f172a; color: rgba(148,163,184,0.15); font-size: 1.5rem;
        }

        /* Keep drawer fully off-screen when closed, even though it's anchored above the footer. */
        .chat-drawer-closed {
            transform: translateY(calc(100% + var(--footer-h) + env(safe-area-inset-bottom, 0px)));
        }
    </style>
</head>

<body class="bg-slate-950 text-white flex flex-col overflow-hidden"
      x-data="roomApp()"
      x-init="init()">

    <!-- Header -->
    <header class="flex-none flex items-center gap-2 px-3 sm:px-5 h-10 bg-slate-900 border-b border-slate-800 z-20">
        <a href="/" class="shrink-0 hover:opacity-80 transition-opacity duration-150" aria-label="2gWatch — home">
            <!-- height fixed to header height via CSS class; width scales automatically -->
            <img src="/logo.svg" alt="2gWatch" width="360" height="96" class="h-6 w-auto" />
        </a>
        <div class="h-3.5 w-px bg-slate-700/50 shrink-0"></div>
        <div class="flex items-center gap-1.5 min-w-0">
            <span class="text-[10px] text-slate-500 uppercase tracking-wider hidden sm:inline shrink-0">Room</span>
            <code class="text-xs font-mono text-slate-200 bg-slate-800 border border-slate-700 px-2 py-0.5 truncate max-w-[100px] sm:max-w-none"
                aria-label="Room ID: @Model.RoomId">@Model.RoomId</code>
            <button id="btnCopyLink"
                class="shrink-0 h-6 w-6 flex items-center justify-center text-slate-500 hover:text-slate-200 hover:bg-slate-700 border border-transparent hover:border-slate-600 transition-colors duration-150"
                title="Copy invite link">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter">
                    <rect x="9" y="9" width="13" height="13" rx="0"></rect>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
            </button>
        </div>
        <div class="flex-1"></div>

        <!-- Landscape controls: compact icon buttons shown only in mobile landscape via CSS -->
        <div id="landscapeControls" class="flex items-center gap-1 shrink-0" style="display: none;">
            <button @@click="$rtc.toggleMic()"
                class="h-8 w-8 flex items-center justify-center text-sm border transition-colors duration-150"
                :class="micActive ? 'bg-slate-700 border-slate-600 text-slate-100' : 'bg-red-900 border-red-700 text-red-300'"
                :title="micActive ? 'Mute microphone' : 'Unmute microphone'">
                <span x-text="micActive ? '🎤' : '🔇'"></span>
            </button>
            <button @@click="$rtc.toggleCamera()"
                class="h-8 w-8 flex items-center justify-center text-sm border transition-colors duration-150"
                :class="camActive ? 'bg-sky-800 border-sky-700 text-sky-200' : 'bg-slate-700 border-slate-600 text-slate-400'"
                :title="camActive ? 'Stop camera' : 'Start camera'">
                &#127909;
            </button>
            <div class="relative">
                <button id="btnChatLandscape"
                    class="h-8 w-8 flex items-center justify-center text-sm border bg-slate-700 border-slate-600 text-slate-300 hover:text-white hover:bg-slate-600 transition-colors duration-150"
                    title="Chat">
                    &#128172;
                </button>
                <span class="absolute -top-0.5 -right-0.5 w-3.5 h-3.5 bg-red-500 text-[8px] flex items-center justify-center font-bold pointer-events-none"
                    x-show="unreadCount > 0"
                    x-text="unreadCount > maxUnreadBadge ? maxUnreadBadge + '+' : unreadCount"
                    style="display: none;"></span>
            </div>
            <a href="/"
                class="h-8 w-8 flex items-center justify-center text-sm border bg-red-900 border-red-700 text-red-300 hover:bg-red-800 transition-colors duration-150"
                title="Leave room">
                &#128682;
            </a>
        </div>

        <div class="flex items-center gap-1.5 shrink-0">
            <span class="status-pulse w-1.5 h-1.5 shrink-0"
                  :class="{ 'bg-green-400': statusColor==='green', 'bg-amber-400': statusColor==='amber', 'bg-red-400': statusColor==='red' }"></span>
            <span id="statusText" class="text-xs text-slate-400 hidden sm:inline truncate max-w-[200px]" x-text="status"></span>
        </div>
    </header>

    <!-- URL Bar -->
    <div id="urlBar" class="flex-none flex items-center px-3 py-1.5 bg-slate-900 border-b border-slate-800 z-10 gap-0">
        <input id="urlInput" type="text"
            placeholder="Paste a YouTube or video URL to watch together…"
            class="flex-1 h-8 text-xs bg-slate-800 border border-slate-700 border-r-0 px-3 text-slate-100
                   placeholder-slate-500 focus:outline-none focus:border-indigo-500 transition-colors duration-150 min-w-0" />
        <button id="btnLoad"
            class="shrink-0 h-8 px-3 bg-indigo-600 hover:bg-indigo-500 border border-indigo-600 hover:border-indigo-500 text-xs font-medium transition-colors duration-150 whitespace-nowrap">
            ▶ Load
        </button>
    </div>

    <!-- Main -->
    <main class="flex-1 flex flex-col lg:flex-row min-h-0 overflow-hidden">

        <!-- Video stage -->
        <div class="flex-1 relative bg-black min-h-0 overflow-hidden flex items-center justify-center">
            <!-- YouTube embed (created by JS) -->
            <div id="ytPlayerContainer" class="hidden absolute inset-0"></div>
            <!-- HTML5 video (direct URL) -->
            <video id="videoPlayer" class="hidden absolute inset-0 w-full h-full object-contain" controls></video>
            <!-- Remote screen share — optimised for low-latency WebRTC playback -->
            <video id="remoteScreen" autoplay playsinline muted disablepictureinpicture
                   style="pointer-events: auto;"
                   class="hidden absolute inset-0 w-full h-full object-contain"></video>
            <!-- Empty-stage placeholder -->
            <div id="stagePlaceholder"
                class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none select-none">
                <div class="border border-slate-800 bg-slate-950/60 p-6 flex flex-col items-center gap-2.5">
                    <span class="text-5xl opacity-20">&#127916;</span>
                    <p class="text-xs text-slate-500 text-center desktop-hint leading-relaxed">Paste a video URL above or share your screen<br/>to start watching together</p>
                    <p class="text-xs text-slate-500 text-center mobile-hint">Waiting for video or screen share…</p>
                </div>
            </div>
        </div>

        <!--
            Right / bottom panel: webcams + chat
            Mobile  : flex-row strip at the bottom (height controlled by .cam-tile CSS)
            Desktop : flex-col, w-72 sidebar on the right
        -->
        <div id="camSidebar" class="flex-none flex flex-row lg:flex-col bg-slate-900 border-t border-slate-800 lg:border-t-0 lg:border-l lg:w-72">

            <!-- Camera tiles — scrollable strip (mobile: horizontal, desktop: vertical) -->
            <div id="camGrid"
                 class="flex flex-row lg:flex-col flex-none overflow-x-auto lg:overflow-x-hidden overflow-y-hidden lg:overflow-y-auto
                        border-b border-slate-800 lg:max-h-72">

                <!-- Local cam tile (always present) -->
                <div id="localCamTile" class="relative flex-none bg-slate-800 overflow-hidden cam-tile w-28 lg:w-full shrink-0">
                    <video id="localCam" autoplay playsinline muted
                        class="absolute inset-0 w-full h-full object-cover -scale-x-100"></video>
                    <div id="localCamPh" class="cam-ph absolute inset-0" aria-label="Local camera inactive" role="img">&#127910;</div>
                    <span class="vid-label" id="localLabel">You</span>
                </div>

            </div>

            <!-- Chat panel (desktop only; mobile uses the drawer below) -->
            <div class="hidden lg:flex flex-1 flex-col min-h-0">
                <div class="px-3 py-1.5 border-b border-slate-800 flex items-center justify-between shrink-0 border-l-2 border-l-indigo-500">
                    <span class="text-[10px] text-slate-300 uppercase tracking-wider font-medium">Chat</span>
                    <span class="text-[10px] text-slate-500" x-text="peerCount > 0 ? (peerCount + 1) + ' in room' : '1 in room'"></span>
                </div>
                <div id="chatMessages" class="flex-1 overflow-y-auto px-3 py-2 space-y-1.5"></div>
                <div class="flex border-t border-slate-800">
                    <input id="chatInput" type="text" placeholder="Message…" maxlength="500" autocomplete="off"
                        class="flex-1 h-8 text-xs bg-slate-800 border-0 px-3 text-slate-100
                               placeholder-slate-500 focus:outline-none focus:bg-slate-700 transition-colors duration-150 min-w-0" />
                    <button id="btnSendChat"
                        class="shrink-0 h-8 px-3 bg-indigo-600 hover:bg-indigo-500 text-xs transition-colors duration-150 border-l border-slate-700">
                        &#10148;
                    </button>
                </div>
            </div>

        </div>
    </main>

    <!-- Mobile Chat Drawer -->
    <div id="chatDrawer"
        class="lg:hidden fixed inset-x-0 h-72 bg-slate-900 border-t border-slate-800
               flex flex-col z-30 transition-transform duration-150 chat-drawer-closed"
        style="bottom: calc(var(--footer-h) + env(safe-area-inset-bottom, 0px));">
        <div class="flex items-center justify-between px-3 py-1.5 border-b border-slate-800 shrink-0 border-l-2 border-l-indigo-500">
            <span class="text-[10px] text-slate-300 uppercase tracking-wider font-medium">Chat</span>
            <button id="btnCloseChat" class="h-6 w-6 flex items-center justify-center text-slate-500 hover:text-slate-200 transition-colors duration-150 text-xs">&#10005;</button>
        </div>
        <div id="chatMessagesMobile" class="flex-1 overflow-y-auto px-3 py-2 space-y-1.5"></div>
        <div class="flex border-t border-slate-800 shrink-0">
            <input id="chatInputMobile" type="text" placeholder="Message…" maxlength="500" autocomplete="off"
                class="flex-1 h-8 text-xs bg-slate-800 border-0 px-3 text-slate-100
                       placeholder-slate-500 focus:outline-none focus:bg-slate-700 transition-colors duration-150 min-w-0" />
            <button id="btnSendChatMobile"
                class="shrink-0 h-8 px-3 bg-indigo-600 hover:bg-indigo-500 text-xs transition-colors duration-150 border-l border-slate-700">
                &#10148;
            </button>
        </div>
    </div>

    <!-- Footer Controls -->
    <footer class="flex-none flex items-center gap-1.5 px-3 sm:px-5 bg-slate-900 border-t border-slate-800 z-20"
            style="min-height: var(--footer-h); padding-bottom: env(safe-area-inset-bottom, 0px);">

        <button @@click="$rtc.toggleMic()"
            class="h-8 flex items-center gap-1.5 px-3 text-xs font-medium border transition-colors duration-150"
            :class="micActive ? 'bg-slate-700 border-slate-600 text-slate-100 hover:bg-slate-600' : 'bg-red-900 border-red-700 text-red-300 hover:bg-red-800'"
            :title="micActive ? 'Mute microphone' : 'Unmute microphone'">
            <span x-text="micActive ? '🎤' : '🔇'"></span>
            <span class="hidden sm:inline" x-text="micActive ? 'Mic' : 'Unmute'"></span>
        </button>

        <button @@click="$rtc.toggleCamera()"
            class="h-8 flex items-center gap-1.5 px-3 text-xs font-medium border transition-colors duration-150"
            :class="camActive ? 'bg-sky-800 border-sky-700 text-sky-100 hover:bg-sky-700' : 'bg-slate-700 border-slate-600 text-slate-400 hover:bg-slate-600'"
            :title="camActive ? 'Stop camera' : 'Start camera'">
            &#127909; <span class="hidden sm:inline" x-text="camActive ? 'Stop Cam' : 'Camera'"></span>
        </button>

        <button id="btnScreenShare"
            @@click="$rtc.toggleScreenShare()"
            class="hidden sm:flex h-8 items-center gap-1.5 px-3 text-xs font-medium border transition-colors duration-150"
            :class="screenActive ? 'bg-indigo-700 border-indigo-600 text-indigo-100 hover:bg-indigo-600' : 'bg-slate-700 border-slate-600 text-slate-400 hover:bg-slate-600'"
            :title="screenActive ? 'Stop screen share' : 'Share screen'">
            &#128187; <span class="hidden sm:inline" x-text="screenActive ? 'Stop Share' : 'Screen'"></span>
        </button>

        <!-- Chat toggle (mobile only) -->
        <div class="relative lg:hidden">
            <button id="btnChat"
                class="h-8 flex items-center gap-1.5 px-3 text-xs font-medium border border-slate-600 bg-slate-700 text-slate-300 hover:bg-slate-600 hover:text-white transition-colors duration-150">
                &#128172;
            </button>
            <span id="chatBadge"
                class="absolute -top-0.5 -right-0.5 w-3.5 h-3.5 bg-red-500
                       text-[8px] flex items-center justify-center font-bold"
                style="display:none"
                x-show="unreadCount > 0"
                x-text="unreadCount > maxUnreadBadge ? maxUnreadBadge + '+' : unreadCount"></span>
        </div>

        <div class="flex-1"></div>

        <a href="/"
            class="h-8 flex items-center gap-1.5 px-3 text-xs font-medium border border-red-700 bg-red-900 text-red-300 hover:bg-red-800 transition-colors duration-150">
            &#128682; <span class="hidden sm:inline">Leave</span>
        </a>
    </footer>
    @if (FeedbackHubOptions.Value.Enabled)
    {
        <script src="https://feedback-hub.lunavex.com/widget/feedback-widget.js"
                data-project-key="@FeedbackHubOptions.Value.PublicKey" data-locale="auto"></script>
    }
    <script>
        const ROOM_ID = "@Model.RoomId";

        function roomApp() {
            return {
                status: "Connecting…",
                statusColor: "amber",
                micActive: true,
                camActive: false,
                screenActive: false,
                unreadCount: 0,
                peerCount: 0,
                // Maximum count shown in the chat unread badge before showing "N+"
                maxUnreadBadge: 9,

                get $rtc() { return window.rtcActions ?? {}; },

                init() {
                    window.alpineApp = this;
                },
            };
        }
    </script>
    <script asp-append-version="true" src="/js/webrtc.js"></script>
    <script src="https://www.youtube.com/iframe_api"></script>
</body>

</html>

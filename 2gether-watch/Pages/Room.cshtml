@page "/room/{id?}"
@model RoomModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>2gether Watch — Room @Model.RoomId</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* True full-height that shrinks with mobile browser chrome */
        body { height: 100dvh; }

        @@supports not (height: 100dvh) {
            body { height: 100vh; }
        }

        .glass {
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.07);
        }

        /* Pill label over video */
        .vid-label {
            position: absolute;
            bottom: 6px;
            left: 8px;
            font-size: 10px;
            line-height: 1;
            color: rgba(255,255,255,0.5);
            background: rgba(0,0,0,0.4);
            padding: 2px 6px;
            border-radius: 4px;
            pointer-events: none;
        }

        /* Status dot pulse */
        @@keyframes status-pulse {
            0%, 100% { opacity: 1; }
            50%       { opacity: 0.35; }
        }
        .status-pulse { animation: status-pulse 1.8s ease-in-out infinite; }
    </style>
</head>

<body class="bg-slate-950 text-white flex flex-col overflow-hidden">

    <!-- ─── Header ─────────────────────────────────────────────── -->
    <header class="flex-none flex items-center gap-3 px-3 sm:px-5 h-11 bg-slate-900/95 backdrop-blur-sm border-b border-white/5 z-20">

        <!-- Brand -->
        <a href="/" class="font-bold text-sm text-white/80 hover:text-white transition shrink-0">
            <span class="text-violet-400">2g</span>Watch
        </a>

        <div class="h-4 w-px bg-white/10 shrink-0"></div>

        <!-- Room ID + copy -->
        <div class="flex items-center gap-1.5 min-w-0">
            <span class="text-xs text-slate-500 hidden sm:inline shrink-0">Room:</span>
            <code class="text-xs font-mono text-slate-300 bg-white/5 px-2 py-0.5 rounded truncate max-w-[120px] sm:max-w-none">@Model.RoomId</code>
            <button id="btnCopyLink"
                class="shrink-0 p-1 text-slate-400 hover:text-white hover:bg-white/5 rounded transition text-sm"
                title="Copy room link">📋</button>
        </div>

        <div class="flex-1"></div>

        <!-- Status indicator -->
        <div class="flex items-center gap-1.5 shrink-0">
            <span id="statusDot" class="status-pulse w-2 h-2 rounded-full bg-amber-400 shrink-0"></span>
            <span id="statusText" class="text-xs text-slate-400 hidden sm:inline max-w-[180px] truncate">
                Waiting for the other person…
            </span>
        </div>
    </header>

    <!-- ─── Main ───────────────────────────────────────────────── -->
    <main class="flex-1 flex flex-col lg:flex-row min-h-0 overflow-hidden">

        <!-- Screen share / primary video -->
        <div class="relative flex-1 bg-black min-h-0 flex items-center justify-center">
            <video id="remoteScreen" autoplay playsinline
                class="w-full h-full object-contain"></video>

            <!-- Placeholder (shown when no screen share) -->
            <div id="screenPlaceholder"
                class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none select-none">
                <span class="text-5xl sm:text-7xl opacity-10">🖥️</span>
                <p class="text-xs text-slate-700 mt-3">No screen share active</p>
            </div>
        </div>

        <!-- ─ Webcam panel (right on desktop, strip at bottom on mobile) ─ -->
        <div class="flex-none flex flex-row lg:flex-col bg-slate-900 border-t border-white/5
                    lg:border-t-0 lg:border-l lg:w-56 xl:w-64
                    h-28 sm:h-36 lg:h-auto">

            <!-- Remote cam -->
            <div class="relative flex-1 bg-slate-800 min-w-0 min-h-0 overflow-hidden">
                <video id="remoteCam" autoplay playsinline
                    class="w-full h-full object-cover"></video>
                <span class="vid-label">Other</span>
            </div>

            <!-- Divider -->
            <div class="w-px lg:w-auto lg:h-px bg-white/5 shrink-0"></div>

            <!-- Local cam -->
            <div class="relative flex-1 bg-slate-800 min-w-0 min-h-0 overflow-hidden">
                <video id="localCam" autoplay playsinline muted
                    class="w-full h-full object-cover -scale-x-100"></video>
                <span class="vid-label">You</span>
            </div>
        </div>
    </main>

    <!-- ─── Controls bar ──────────────────────────────────────── -->
    <footer class="flex-none flex items-center gap-2 px-3 sm:px-5 h-14 bg-slate-900/95 backdrop-blur-sm border-t border-white/5 z-20">

        <button id="btnCam"
            class="flex items-center gap-1.5 px-3 sm:px-4 py-2 rounded-full text-sm font-medium transition-all
                   active:scale-95 shadow-sm bg-sky-700 hover:bg-sky-600 ring-1 ring-sky-600/30">
            🎥 <span class="hidden sm:inline">Camera</span>
        </button>

        <button id="btnShare"
            class="flex items-center gap-1.5 px-3 sm:px-4 py-2 rounded-full text-sm font-medium transition-all
                   active:scale-95 shadow-sm bg-violet-700 hover:bg-violet-600 ring-1 ring-violet-600/30">
            🖥️ <span class="hidden sm:inline">Screen</span>
        </button>

        <!-- Mobile status -->
        <div class="flex items-center gap-1.5 sm:hidden ml-1">
            <span class="status-pulse w-1.5 h-1.5 rounded-full bg-amber-400" id="statusDotMobile"></span>
        </div>

        <div class="flex-1"></div>

        <a href="/"
            class="flex items-center gap-1.5 px-3 sm:px-4 py-2 rounded-full text-sm font-medium transition-all
                   active:scale-95 bg-red-700/80 hover:bg-red-600 ring-1 ring-red-600/30">
            🚪 <span class="hidden sm:inline">Leave</span>
        </a>
    </footer>

    <script>
        const ROOM_ID = "@Model.RoomId";
    </script>
    <script src="/js/webrtc.js"></script>

    <script>
        // ── Copy room link ───────────────────────────────────────────
        const copyBtn = document.getElementById("btnCopyLink");

        function setCopy(icon) {
            copyBtn.textContent = icon;
            setTimeout(() => { copyBtn.textContent = "📋"; }, 1600);
        }

        function fallbackCopy(text) {
            const ta = document.createElement("textarea");
            ta.value = text;
            ta.style.cssText = "position:fixed;opacity:0";
            document.body.appendChild(ta);
            ta.select();
            try { return document.execCommand("copy"); }
            finally { document.body.removeChild(ta); }
        }

        copyBtn.addEventListener("click", () => {
            const url = location.href;
            if (navigator.clipboard?.writeText) {
                navigator.clipboard.writeText(url)
                    .then(() => setCopy("✅"))
                    .catch(() => setCopy(fallbackCopy(url) ? "✅" : "❌"));
            } else {
                setCopy(fallbackCopy(url) ? "✅" : "❌");
            }
        });

        // ── Screen-share placeholder ─────────────────────────────────
        const remoteScreenEl = document.getElementById("remoteScreen");
        const placeholderEl  = document.getElementById("screenPlaceholder");

        function syncPlaceholder() {
            placeholderEl.classList.toggle("hidden", !!remoteScreenEl.srcObject);
        }
        remoteScreenEl.addEventListener("loadedmetadata", syncPlaceholder);
        setInterval(syncPlaceholder, 500);

        // ── Mirror status dot on mobile ──────────────────────────────
        // The webrtc.js updateStatus() targets #statusDot; keep the mobile
        // dot in sync by observing class changes on the main dot.
        const mainDot   = document.getElementById("statusDot");
        const mobileDot = document.getElementById("statusDotMobile");
        const DOT_COLORS = ["bg-amber-400", "bg-green-400", "bg-red-400"];
        const dotObserver = new MutationObserver(() => {
            DOT_COLORS.forEach(cls => mobileDot.classList.remove(cls));
            const active = DOT_COLORS.find(cls => mainDot.classList.contains(cls));
            if (active) mobileDot.classList.add(active);
        });
        dotObserver.observe(mainDot, { attributes: true, attributeFilter: ["class"] });
    </script>
</body>

</html>

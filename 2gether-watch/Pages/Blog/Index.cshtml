@page "/blog"
@model _2gether_watch.Pages.Blog.IndexModel
@{
    ViewData["Title"] = "Watch Party & Sync Guides - 2gether Watch Blog";
    ViewData["BodyClass"] = "min-h-screen bg-slate-950 text-slate-100";
}

@section Head {
    <meta name="description" content="Guides on watch parties, video sync, screen sharing, and watching movies or YouTube together online with 2gether Watch — a free, no-signup app." />
    <link rel="canonical" href="@Model.BaseUrl/blog" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Watch Party & Sync Guides - 2gether Watch Blog" />
    <meta property="og:description" content="Guides on watch parties, video sync, screen sharing, and watching movies or YouTube together online with 2gether Watch — a free, no-signup app." />
    <meta property="og:url" content="@Model.BaseUrl/blog" />
}

<main class="mx-auto max-w-3xl px-5 py-10 sm:py-14">
    <a href="/" class="inline-flex items-center text-sm text-slate-400 hover:text-white transition-colors">← Back to 2gether Watch</a>

    <header class="mt-8 space-y-3">
        <p class="text-xs uppercase tracking-wider text-slate-500">Blog</p>
        <h1 class="text-3xl font-semibold text-white">2gether Watch Blog</h1>
    </header>

    <div class="mt-8 space-y-6">
        @if (Model.Posts.Count == 0)
        {
            <p class="text-slate-400">No posts yet — check back soon.</p>
        }
        else
        {
            @foreach (var post in Model.Posts)
            {
                <article class="border-b border-slate-700/60 pb-6">
                    <a href="/blog/@post.Slug" class="text-xl font-semibold text-white hover:text-indigo-500 transition-colors">@post.Title</a>
                    <p class="mt-1 text-xs text-slate-500">@post.Date.ToString("MMMM d, yyyy")</p>
                    <p class="mt-2 text-slate-400 leading-7">@post.Description</p>
                </article>
            }
        }
    </div>
</main>
